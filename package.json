{
  "name": "StockHub",
  "version": "1.0.0",
  "description": "StockHub - Sistema de gestion de stock",
  "author": "RPPRO",
  "main": "./src/index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export-web": "expo export --platform web",
    "build-electron": "tsc electron/main.ts electron/preload.ts --outDir electron",
    "fix-web-paths": "node ./scripts/fix-web-paths.js",
    "desktop": "npm run export-web && npm run fix-web-paths && npm run build-electron && electron electron/main.js",
    "dist-win": "npm run export-web && npm run fix-web-paths && npm run build-electron && electron-builder --win"
  },
  "build": {
    "appId": "com.rppro.stock",
    "productName": "StockHub",
    "icon": "assets/StockHub.png",
    "compression": "maximum",
    "asar": true,
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "portable",
      "icon": "assets/StockHub.png"
    },
    "extraMetadata": {
      "main": "./electron/main.js"
    }
  },
  "expo": {
    "entry-point": "./index.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "axios": "^1.13.5",
    "cli": "^1.0.1",
    "eas": "^0.1.0",
    "expo": "~54.0.32",
    "expo-camera": "~17.0.10",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "~19.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
